# ConstructAI Mobile Environment Configuration
# Copy this file to .env and update with your actual values

# App Configuration
APP_NAME=ConstructAI Safety
APP_VERSION=1.0.0
APP_ENVIRONMENT=development

# Backend API Configuration
API_BASE_URL=http://localhost:3001/api
SUPABASE_URL=your-supabase-project-url
SUPABASE_ANON_KEY=your-supabase-anon-key

# Security & Authentication
JWT_SECRET=mobile-app-jwt-secret
ENCRYPTION_KEY=32-character-encryption-key

# Offline & Sync Settings
OFFLINE_STORAGE_LIMIT=500MB
SYNC_INTERVAL_MINUTES=15
MAX_RETRY_ATTEMPTS=5

# AI & Feature Flags
ENABLE_AI_ANALYSIS=true
ENABLE_VOICE_COMMANDS=true
ENABLE_QR_SCANNER=true
ENABLE_OFFLINE_MODE=true

# Development Settings
EXPO_DEBUG=true
LOG_LEVEL=info
ENABLE_ANALYTICS=false

# File Upload Settings
MAX_PHOTO_SIZE=5MB
MAX_VIDEO_SIZE=50MB
SUPPORTED_FORMATS=jpg,jpeg,png,mp4,mov

# GPS & Location Settings
GPS_ACCURACY=high
LOCATION_TIMEOUT=30000
UPDATE_INTERVAL_SECONDS=5

# Notification Settings
ENABLE_PUSH_NOTIFICATIONS=true
CRITICAL_ALERTS_ALWAYS=true
QUIET_HOURS_START=22:00
QUIET_HOURS_END=07:00

# Report & Compliance Settings
AUTO_GENERATE_REPORTS=true
DEFAULT_REPORT_FORMAT=pdf
COMPLIANCE_STANDARDS=iso_45001,osha_standards
RETENTION_PERIOD_DAYS=365
