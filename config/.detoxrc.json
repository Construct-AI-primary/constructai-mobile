{
  "testRunner": "jest",
  "runnerConfig": "e2e/jest.config.js",
  "configurations": {
    "ios.simulator": {
      "type": "ios.simulator",
      "binaryPath": "ios/build/Build/Products/Debug-iphonesimulator/ConstructAI.app",
      "build": "xcodebuild -workspace ios/ConstructAI.xcworkspace -scheme ConstructAI -configuration Debug -sdk iphonesimulator -derivedDataPath ios/build",
      "device": {
        "type": "iPhone 14"
      }
    },
    "android.emulator": {
      "type": "android.emulator",
      "binaryPath": "android/app/build/outputs/apk/debug/app-debug.apk",
      "build": "cd android && ./gradlew assembleDebug assembleAndroidTest -DtestBuildType=debug",
      "device": {
        "avdName": "Pixel_5_API_33"
      }
    },
    "ios.simulator.release": {
      "type": "ios.simulator",
      "binaryPath": "ios/build/Build/Products/Release-iphonesimulator/ConstructAI.app",
      "build": "xcodebuild -workspace ios/ConstructAI.xcworkspace -scheme ConstructAI -configuration Release -sdk iphonesimulator -derivedDataPath ios/build",
      "device": {
        "type": "iPhone 14"
      }
    },
    "android.emulator.release": {
      "type": "android.emulator",
      "binaryPath": "android/app/build/outputs/apk/release/app-release.apk",
      "build": "cd android && ./gradlew assembleRelease assembleAndroidTest -DtestBuildType=release",
      "device": {
        "avdName": "Pixel_5_API_33"
      }
    }
  },
  "artifacts": {
    "plugins": {
      "screenshot": {
        "shouldTakeAutomaticSnapshots": true,
        "takeWhen": {
          "testStart": true,
          "testDone": true,
          "assertion": true
        }
      },
      "video": "failing",
      "log": "failing",
      "uiHierarchy": "failing"
    }
  }
}
